# --- Django ---
SECRET_KEY=buraya-en-az-50-karakterlik-rastgele-bir-anahtar-girin
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Veritabanı ---
# Kurulumsuz hızlı başlangıç için True bırakın (SQLite).
# PostgreSQL kullanmak için False yapın ve aşağıdaki DB_* değerlerini doldurun.
USE_SQLITE=True
DB_NAME=projeharitasi
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- JWT ---
JWT_EXPIRE_HOURS=24

# --- CORS ---
CORS_ALLOW_ALL_ORIGINS=True
